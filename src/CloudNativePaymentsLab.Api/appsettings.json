{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=cloud_native_payments;Username=postgres;Password=postgres"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ConsumerGroupId": "cloud-native-payments-lab",
    "Topics": {
      "OrderCreated": "orders.order-created",
      "PaymentApproved": "payments.payment-approved",
      "PaymentFailed": "payments.payment-failed",
      "PaymentsDeadLetter": "payments.dlq"
    }
  },
  "Outbox": {
    "PollingIntervalSeconds": 2,
    "BatchSize": 10,
    "MaxRetryCount": 5
  },
  "Payments": {
    "MaxProcessingAttempts": 5,
    "RetryDelaySeconds": 5,
    "RetryPollingIntervalSeconds": 2
  },
  "FakePaymentProvider": {
    "BaseUrl": "http://localhost:8081",
    "Mode": "Random",
    "SuccessRate": 80,
    "TemporaryFailureRate": 10,
    "PermanentFailureRate": 5,
    "TimeoutRate": 5,
    "ArtificialDelayMs": 200
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}
